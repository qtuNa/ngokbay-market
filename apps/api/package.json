{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check-types": "tsc --noEmit",
    "migrate:create": "node-pg-migrate create -j js",
    "migrate:up": "node scripts/migrate.mjs up",
    "migrate:down": "node scripts/migrate.mjs down"
  },
  "dependencies": {
    "@fastify/jwt": "^9.1.0",
    "@types/pg": "^8.20.0",
    "@repo/validation": "workspace:*",
    "@repo/maps": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  }
}
