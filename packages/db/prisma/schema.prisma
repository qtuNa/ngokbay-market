// Ngok Bay — PostgreSQL schema (MVP + Seller)
// Spec: docs-wiki/Concepts/ngokbay-database-schema.md
// Vietnamese full-text search: pg_trgm + GIN indexes (see prisma/migrations README)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  BUYER          @map("BUYER")
  SELLER         @map("SELLER") // Merchant / người bán OCOP
  CONTENT_EDITOR @map("CONTENT_EDITOR")
  ADMIN          @map("ADMIN")

  @@map("user_role")
}

enum ProductStatus {
  draft          @map("draft")
  pending_review @map("pending_review")
  published      @map("published")
  rejected       @map("rejected")

  @@map("product_status")
}

enum MediaType {
  image @map("image")
  video @map("video")

  @@map("media_type")
}

enum LibraryMediaType {
  image @map("image")
  video @map("video")
  audio @map("audio")
  pdf   @map("pdf")

  @@map("library_media_type")
}

enum MarketEventStatus {
  draft     @map("draft")
  published @map("published")
  cancelled @map("cancelled")

  @@map("market_event_status")
}

enum PaymentMethod {
  bank_transfer @map("bank_transfer")
  momo          @map("momo")
  vnpay         @map("vnpay")

  @@map("payment_method")
}

enum PaymentStatus {
  pending  @map("pending")
  paid     @map("paid")
  failed   @map("failed")
  refunded @map("refunded")

  @@map("payment_status")
}

enum OrderStatus {
  pending_payment @map("pending_payment")
  confirmed       @map("confirmed")
  processing      @map("processing")
  shipped         @map("shipped")
  delivered       @map("delivered")
  cancelled       @map("cancelled")

  @@map("order_status")
}

enum BlogCategory {
  culture @map("culture")
  craft   @map("craft")
  event   @map("event")
  news    @map("news")

  @@map("blog_category")
}

enum BlogPostStatus {
  draft     @map("draft")
  published @map("published")

  @@map("blog_post_status")
}

enum NotificationType {
  market_event @map("market_event")

  @@map("notification_type")
}

enum NotificationStatus {
  pending @map("pending")
  sent    @map("sent")
  failed  @map("failed")

  @@map("notification_status")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

/// Khách hàng / Merchant (SELLER) / Admin — định danh chính bằng SĐT
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String   @unique @db.VarChar(15)
  name      String?  @db.VarChar(100)
  email     String?  @unique @db.VarChar(255)
  role      UserRole @default(BUYER)
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  products      Product[]      @relation("ProductSeller")
  marketEvents  MarketEvent[]  @relation("MarketEventCreator")
  orders        Order[]
  blogPosts     BlogPost[]
  mediaLibrary  MediaLibrary[]

  @@index([phone])
  @@index([role, isActive])
  @@map("users")
}

/// Giỏ hàng khách (guest) — merge sau khi đăng nhập OTP
model GuestCart {
  sessionToken String   @id @map("session_token") @db.VarChar(64)
  items        Json     @default("[]")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("guest_carts")
}

// ─── Products & Categories ───────────────────────────────────────────────────

model Category {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(100)
  slug      String  @unique @db.VarChar(100)
  iconUrl   String? @map("icon_url")
  parentId  Int?    @map("parent_id")
  sortOrder Int     @default(0) @map("sort_order")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId, sortOrder])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_categories_name_trgm")
  @@map("categories")
}

model Artisan {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(100)
  bio       String?
  photoUrl  String? @map("photo_url")
  village   String? @db.VarChar(100)
  specialty String? @db.VarChar(100)

  products Product[]

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_artisans_name_trgm")
  @@index([village])
  @@map("artisans")
}

/// Đặc sản OCOP — liên kết Merchant qua sellerId (User role SELLER)
model Product {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  description   String?
  price         Decimal       @db.Decimal(12, 0)
  stock         Int           @default(0)
  categoryId    Int?          @map("category_id")
  artisanId     Int?          @map("artisan_id")
  ocopRating    Int?          @map("ocop_rating") @db.SmallInt
  sellerId      String?       @map("seller_id") @db.Uuid
  status        ProductStatus @default(draft)
  rejectionNote String?       @map("rejection_note")
  isFeatured    Boolean       @default(false) @map("is_featured")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  category      Category?      @relation(fields: [categoryId], references: [id])
  artisan       Artisan?       @relation(fields: [artisanId], references: [id])
  seller        User?          @relation("ProductSeller", fields: [sellerId], references: [id])
  media         ProductMedia[]
  eventProducts EventProduct[]
  orderItems    OrderItem[]

  @@index([categoryId], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@index([sellerId, status])
  @@index([isFeatured, status])
  // Partial index (migration SQL): CREATE INDEX idx_products_ocop ON products(ocop_rating) WHERE ocop_rating IS NOT NULL;
  @@index([ocopRating], map: "idx_products_ocop")
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_products_name_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_products_description_trgm")
  // Composite tsvector (migration SQL):
  // CREATE INDEX idx_products_fts ON products USING GIN(to_tsvector('simple', name || ' ' || COALESCE(description, '')));
  @@map("products")
}

model ProductMedia {
  id           Int       @id @default(autoincrement())
  productId    String    @map("product_id") @db.Uuid
  type         MediaType
  s3Key        String    @map("s3_key")
  thumbnailKey String?   @map("thumbnail_key")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_product_media")
  @@map("product_media")
}

// ─── Market Events ───────────────────────────────────────────────────────────

/// Lịch trình phiên chợ — tọa độ lat/lng phục vụ bản đồ
model MarketEvent {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String            @db.VarChar(255)
  description    String?
  eventDate      DateTime          @map("event_date") @db.Date
  startTime      DateTime?         @map("start_time") @db.Time(6)
  endTime        DateTime?         @map("end_time") @db.Time(6)
  locationText   String            @map("location_text")
  lat            Decimal?          @db.Decimal(10, 8)
  lng            Decimal?          @db.Decimal(11, 8)
  mapsUrl        String?           @map("maps_url")
  formattedAddr  String?           @map("formatted_addr")
  status         MarketEventStatus @default(draft)
  bannerUrl      String?           @map("banner_url")
  createdById    String?           @map("created_by") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy     User?          @relation("MarketEventCreator", fields: [createdById], references: [id])
  eventProducts EventProduct[]

  @@index([eventDate, status], map: "idx_events_date")
  @@index([status])
  @@index([lat, lng])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_market_events_title_trgm")
  @@index([locationText(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_market_events_location_trgm")
  @@map("market_events")
}

model EventProduct {
  id        Int     @id @default(autoincrement())
  eventId   String  @map("event_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  boothNo   String? @map("booth_no") @db.VarChar(20)

  event   MarketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id])

  @@unique([eventId, productId])
  @@index([productId])
  @@map("event_products")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?       @map("user_id") @db.Uuid
  orderCode        String        @unique @map("order_code") @db.VarChar(20)
  subtotal         Decimal       @db.Decimal(12, 0)
  shippingFee      Decimal       @default(0) @map("shipping_fee") @db.Decimal(12, 0)
  total            Decimal       @db.Decimal(12, 0)
  shippingName     String        @map("shipping_name") @db.VarChar(100)
  shippingPhone    String        @map("shipping_phone") @db.VarChar(15)
  shippingAddress  String        @map("shipping_address")
  shippingProvince String        @map("shipping_province") @db.VarChar(100)
  shippingDistrict String?       @map("shipping_district") @db.VarChar(100)
  shippingWard     String?       @map("shipping_ward") @db.VarChar(100)
  note             String?
  paymentMethod    PaymentMethod @map("payment_method")
  paymentStatus    PaymentStatus @default(pending) @map("payment_status")
  status           OrderStatus   @default(pending_payment)
  trackingCode     String?       @map("tracking_code") @db.VarChar(100)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId, createdAt(sort: Desc)], map: "idx_orders_user")
  @@index([status], map: "idx_orders_status")
  @@index([orderCode], map: "idx_orders_code")
  @@index([paymentStatus])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

/// Chi tiết dòng đơn hàng (snapshot tại thời điểm checkout)
model OrderItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid
  name      String  @db.VarChar(255)
  price     Decimal @db.Decimal(12, 0)
  quantity  Int
  thumbnail String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─── Content & Notifications ─────────────────────────────────────────────────

model BlogPost {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String         @db.VarChar(255)
  slug        String         @unique @db.VarChar(255)
  content     String
  excerpt     String?
  coverImage  String?        @map("cover_image")
  category    BlogCategory?
  authorId    String?        @map("author_id") @db.Uuid
  status      BlogPostStatus @default(draft)
  publishedAt DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  author User? @relation(fields: [authorId], references: [id])

  @@index([status, publishedAt(sort: Desc)])
  @@index([category, status])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_blog_posts_title_trgm")
  @@map("blog_posts")
}

model Notification {
  id        Int                @id @default(autoincrement())
  phone     String?            @db.VarChar(15)
  email     String?            @db.VarChar(255)
  type      NotificationType   @default(market_event)
  status    NotificationStatus @default(pending)
  sentAt    DateTime?          @map("sent_at") @db.Timestamptz(6)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@index([phone])
  @@map("notifications")
}

model MediaLibrary {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type       LibraryMediaType
  s3Key      String           @map("s3_key")
  altText    String?          @map("alt_text")
  tags       String[]
  uploadedBy String?          @map("uploaded_by") @db.Uuid
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  uploader User? @relation(fields: [uploadedBy], references: [id])

  @@index([tags], type: Gin, map: "idx_media_tags")
  @@index([type, createdAt(sort: Desc)])
  @@map("media_library")
}
